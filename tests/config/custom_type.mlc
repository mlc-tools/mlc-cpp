class CustomType:cpp
{
	std::variant<Transform, Movement, Movement2, Movement3> component_main
	list<std::variant<Transform, Movement, Movement2, Movement3>> components

	fn bool initialize()
	{
		component_main = Transform();
		components.emplace_back(Transform());
		components.emplace_back(Movement());
		components.emplace_back(Movement2());
		components.emplace_back(Movement3());

		std::get<Transform>(components[0]).x = 1;
		std::get<Transform>(components[0]).y = 2;
		std::get<Movement>(components[1]).x = 3;
		std::get<Movement>(components[1]).y = 4;
		std::get<Movement2>(components[2]).x = 5;
		std::get<Movement2>(components[2]).y = 6;
		return true;
	}
}

class TestCustomType<ITestCustomType>:cpp
{
	fn void test_serialize()
	{
		CustomType custom;
		custom.initialize();
		auto clone = clone_object<CustomType>(&custom);

		this->assertEqual(*clone, custom);
	}
}
